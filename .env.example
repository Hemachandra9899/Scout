DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

REDIS_URL="redis://redis:6379"

QDRANT_URL="http://qdrant:6333"
QDRANT_COLLECTION="rlm_chunks"

API_PORT=8000
NEXT_PUBLIC_API_URL="http://localhost:8000"

RLM_RUNTIME_URL="http://rlm-runtime:8787"
MODEL_SERVICE_URL="http://model-service:8100"

NVIDIA_API_KEY=""
NVIDIA_REASONING_MODEL="meta/llama-3.3-70b-instruct"
NVIDIA_CODER_MODEL="qwen/qwen2-7b-instruct"

FIRECRAWL_API_KEY=""
GITHUB_TOKEN=""
MAX_CONTEXT_TOKENS=24000
TAVILY_API_KEY=""

# Search providers
# Posture: Tavily -> GitHub -> local fetch, Firecrawl OFF by default.
# Firecrawl is treated as optional; if its key is present but credits are
# exhausted, the run marks it exhausted and continues with other providers.
FIRECRAWL_ENABLED=false
TAVILY_ENABLED=true
GITHUB_ENABLED=true
# LOCAL_CRAWL_ENABLED=true   # (M1 follow-up: direct fetch of seeded official URLs)
# BRAVE_SEARCH_ENABLED=false # (reserved)
# BRAVE_SEARCH_API_KEY=

# LLM intent classifier (M3). Default OFF. Only activates at confidence < threshold.
ROUTER_LLM_INTENT_ENABLED=false
ROUTER_LLM_INTENT_THRESHOLD=0.75
ROUTER_LLM_INTENT_TIMEOUT_MS=4000
