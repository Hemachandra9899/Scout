# ──────────────────────────────────────────────
# Docker Compose stack (docker compose up)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/scout?schema=public"
DIRECT_URL="postgresql://postgres:postgres@postgres:5432/scout"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scout

REDIS_URL="redis://redis:6379"

QDRANT_URL="http://qdrant:6333"
QDRANT_COLLECTION="rlm_chunks"

API_PORT=8000
NEXT_PUBLIC_API_URL="http://localhost:8000"

RLM_RUNTIME_URL="http://rlm-runtime:8787"
MODEL_SERVICE_URL="http://model-service:8100"

# ──────────────────────────────────────────────
# Local / non-Docker (replace postgres -> localhost)
# ──────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scout?schema=public"
# REDIS_URL="redis://localhost:6379"
# QDRANT_URL="http://localhost:6333"
# MODEL_SERVICE_URL="http://localhost:8100"

# ──────────────────────────────────────────────
# NVIDIA
# ──────────────────────────────────────────────
NVIDIA_API_KEY=""
NVIDIA_REASONING_MODEL="meta/llama-3.3-70b-instruct"
NVIDIA_CODER_MODEL="z-ai/glm-5.1"

# ──────────────────────────────────────────────
# API keys
# ──────────────────────────────────────────────
FIRECRAWL_API_KEY=""
GITHUB_TOKEN=""
TAVILY_API_KEY=""

# ──────────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────────
FIRECRAWL_ENABLED=false
SCOUT_CACHE_ENABLED=true
ROUTER_LLM_INTENT_ENABLED=false
RERANKER_LLM_ENABLED=false
AGENT_EXECUTOR_ENABLED=false
RLM_SANDBOX_ISOLATION_MODE=worker
TAVILY_ENABLED=true
GITHUB_ENABLED=true
MEMORY_RECALL_MIN_SCORE=0.2
MEMORY_RECALL_MAX_CONTEXT=8
RESEARCH_PARALLELISM=4
FOCUSED_RETRY_MAX_RESOURCES=4
FOCUSED_RETRY_TIMEOUT_MS=45000

# ──────────────────────────────────────────────
# LLM intent classifier (M3). Default OFF.
# ──────────────────────────────────────────────
ROUTER_LLM_INTENT_THRESHOLD=0.75
ROUTER_LLM_INTENT_TIMEOUT_MS=4000
