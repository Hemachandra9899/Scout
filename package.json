{
  "name": "rlm-forge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/worker",
    "packages/database",
    "packages/queue",
    "packages/clients",
    "packages/retrieval",
    "packages/knowledge"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "worker": "npm --workspace apps/worker run start",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "typecheck:api": "npm --workspace apps/api run typecheck",
    "test:api": "npm --workspace apps/api run test",
    "typecheck:knowledge": "npm --workspace packages/knowledge run typecheck",
    "test:knowledge": "npm --workspace packages/knowledge test",
    "test:providers": "npm --workspace packages/knowledge run test:providers",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "benchmark:research": "node benchmarks/run-research-benchmark.mjs",
    "eval": "node benchmarks/eval/run-eval.mjs",
    "eval:ci": "EVAL_FAIL_UNDER=0.7 node benchmarks/eval/run-eval.mjs"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
