{
  "name": "rlm-forge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/worker",
    "packages/database",
    "packages/queue",
    "packages/clients",
    "packages/retrieval",
    "packages/knowledge"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "worker": "npm --workspace apps/worker run start",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "typecheck:api": "npm --workspace apps/api run typecheck",
    "test:api": "npm --workspace apps/api run test",
    "typecheck:knowledge": "npm --workspace packages/knowledge run typecheck",
    "test:knowledge": "npm --workspace packages/knowledge test",
    "test:providers": "npm --workspace packages/knowledge run test:providers",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "benchmark:research": "npm run harness:research",
    "eval": "npm run harness:eval",
    "eval:ci": "npm run harness:ci",
    "eval:phase2": "EVAL_TARGET=router EVAL_CASES_DIR=harness/eval/phase2-cases node harness/eval/run-eval.mjs",
    "eval:analyze": "npm run harness:analyze",
    "harness:research": "node harness/run-research-benchmark.mjs",
    "harness:eval": "node harness/eval/run-eval.mjs",
    "harness:ci":
      "EVAL_TARGET=router EVAL_PROJECT_ID=a26d90b1-dc27-43de-a1dd-5c961d54ca0e EVAL_FAIL_UNDER=0.7 EVAL_GATE_PASS_RATE=0.9 EVAL_GATE_MIN_REWARD=5.0 EVAL_GATE_ROUTING=1.0 node harness/eval/run-eval.mjs",
    "harness:analyze": "node harness/eval/analyze-run.mjs"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
